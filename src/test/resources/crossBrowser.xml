    <test name="Firefox">
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.NewAccountTest"/>
            <class name="tests.NewContactTest"/>
            <parameter name="browser" value="firefox"/>
        </classes>
    </test>
</suite>